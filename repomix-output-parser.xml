)


@pytest.fixture
def parser() -> StackMachineParser:
    """Create a parser configured with 2-space indentation."""
    return LogosParser(tab_size=2)


@pytest.mark.parametrize(
    ("line", "expected"),
    [
        (":LOGBOOK:", True),
        ("  :logbook:", True),
        ("CLOCK: [2026-04-25 Sat 10:12]--[2026-04-25 Sat 10:30]", True),
        ("collapsed:: true", True),
